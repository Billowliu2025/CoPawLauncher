<UserControl x:Class="CoPawLauncher.AboutDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             Width="400"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题和图标 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="RocketLaunch" 
                                    Width="64" Height="64"
                                    Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="CoPaw Launcher" 
                       FontSize="24" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
            <TextBlock Text="版本 1.0.0" 
                       FontSize="14"
                       Opacity="0.7"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 描述信息 -->
        <Border Grid.Row="1" 
                Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="CoPaw 快捷启动器" 
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="一个基于 WPF (.NET 10) 的 CoPaw 快捷启动应用程序，内嵌 WebView2 浏览器直接访问 CoPaw 聊天界面。"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Opacity="0.8"
                           LineHeight="20"/>
                
                <Separator Margin="0,12,0,12" Background="{DynamicResource MaterialDesignDivider}"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <materialDesign:PackIcon Kind="CodeTags" 
                                            Width="16" Height="16"
                                            Margin="0,0,8,0"
                                            Opacity="0.7"/>
                    <TextBlock Text="技术栈：WPF, .NET 10, WebView2, MaterialDesign"
                               FontSize="12"
                               Opacity="0.7"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <materialDesign:PackIcon Kind="License" 
                                            Width="16" Height="16"
                                            Margin="0,0,8,0"
                                            Opacity="0.7"/>
                    <TextBlock Text="许可证：MIT License"
                               FontSize="12"
                               Opacity="0.7"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <materialDesign:PackIcon Kind="Github" 
                                            Width="16" Height="16"
                                            Margin="0,0,8,0"
                                            Opacity="0.7"/>
                    <TextBlock FontSize="12" Opacity="0.7">
                        <Hyperlink NavigateUri="https://github.com/Billowliu2025/CoPawLauncher"
                                  RequestNavigate="GitHubLink_RequestNavigate">
                            GitHub: Billowliu2025/CoPawLauncher
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 关闭按钮 -->
        <Button Grid.Row="2"
                Style="{StaticResource MaterialDesignRaisedButton}"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"
                Padding="24,8"
                materialDesign:ButtonAssist.CornerRadius="8"
                Content="关闭"/>
    </Grid>
</UserControl>
