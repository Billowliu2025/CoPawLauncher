<Window x:Class="CoPawLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="CoPaw Launcher" 
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Icon="../Assets/favicon.ico"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        WindowStyle="None"
        AllowsTransparency="True"
        MinWidth="400" MinHeight="300">

    <materialDesign:DialogHost Identifier="RootDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 窗口边缘拖拽调整大小区域 -->
            <Grid x:Name="ResizeGrid" Grid.RowSpan="3" Panel.ZIndex="100">
                <Rectangle x:Name="ResizeTop" Fill="Transparent" Height="5" VerticalAlignment="Top" Cursor="SizeNS" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
                <Rectangle x:Name="ResizeBottom" Fill="Transparent" Height="5" VerticalAlignment="Bottom" Cursor="SizeNS" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
                <Rectangle x:Name="ResizeLeft" Fill="Transparent" Width="5" HorizontalAlignment="Left" Cursor="SizeWE" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
                <Rectangle x:Name="ResizeRight" Fill="Transparent" Width="5" HorizontalAlignment="Right" Cursor="SizeWE" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
                <Rectangle x:Name="ResizeTopLeft" Fill="Transparent" Width="8" Height="8" VerticalAlignment="Top" HorizontalAlignment="Left" Cursor="SizeNWSE" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
                <Rectangle x:Name="ResizeTopRight" Fill="Transparent" Width="8" Height="8" VerticalAlignment="Top" HorizontalAlignment="Right" Cursor="SizeNESW" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
                <Rectangle x:Name="ResizeBottomLeft" Fill="Transparent" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Cursor="SizeNESW" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
                <Rectangle x:Name="ResizeBottomRight" Fill="Transparent" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Cursor="SizeNWSE" MouseLeftButtonDown="Resize_MouseLeftButtonDown"/>
            </Grid>

            <!-- 标题栏（带阴影，可拖动） -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    Padding="0,0,0,0"
                    x:Name="TitleBar"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" 
                                     ShadowDepth="2" 
                                     Opacity="0.3"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左上角菜单按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 菜单按钮 -->
                        <Button x:Name="MenuButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Click="MenuButton_Click"
                                ToolTip="菜单"
                                Margin="8,8,0,8"
                                Foreground="{DynamicResource PrimaryHueMidForegroundBrush}">
                            <materialDesign:PackIcon Kind="Menu" Width="24" Height="24"/>
                        </Button>
                        
                        <!-- 应用标题 -->
                        <TextBlock Text="CoPaw 快捷启动器" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- 右上角按钮组：刷新、最小化、最大化、关闭 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- 刷新按钮 -->
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Click="RefreshButton_Click"
                                ToolTip="刷新页面 (F5)"
                                Margin="0,8,0,8"
                                Foreground="{DynamicResource PrimaryHueMidForegroundBrush}">
                            <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                        </Button>
                        
                        <!-- 分隔线 -->
                        <Rectangle Width="1" 
                                   Height="30" 
                                   Fill="{DynamicResource MaterialDesignDivider}"
                                   Margin="8,8,8,8"
                                   VerticalAlignment="Center"/>
                        
                        <!-- 最小化 -->
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Click="MinimizeButton_Click"
                                ToolTip="最小化"
                                Margin="0,8,0,8"
                                Foreground="{DynamicResource PrimaryHueMidForegroundBrush}">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="20" Height="20"/>
                        </Button>
                        
                        <!-- 最大化/还原 -->
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Click="MaximizeButton_Click"
                                ToolTip="最大化/还原"
                                Margin="0,8,0,8"
                                Foreground="{DynamicResource PrimaryHueMidForegroundBrush}">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="20" Height="20" x:Name="MaximizeIcon"/>
                        </Button>
                        
                        <!-- 关闭 -->
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Click="CloseButton_Click"
                                ToolTip="关闭"
                                Margin="0,8,8,8"
                                Foreground="{DynamicResource PrimaryHueMidForegroundBrush}">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WebView2 浏览器 -->
            <!-- WebView2 浏览器（由 code-behind 初始化后导航） -->
            <wv2:WebView2 Grid.Row="1" 
                          x:Name="WebView"
                          Margin="0"/>

            <!-- 状态栏 -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource PrimaryHueLightBrush}"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" 
                                                Foreground="{DynamicResource PrimaryHueLightForegroundBrush}" 
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"
                                                Width="20" Height="20"
                                                x:Name="StatusIcon"/>
                        <TextBlock Text="状态：" 
                                   Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="14"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" 
                               x:Name="StatusText"
                               Text="正在加载 CoPaw..." 
                               Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- 下拉菜单 -->
            <Popup x:Name="MainMenuPopup"
                   PlacementTarget="{Binding ElementName=MenuButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   PopupAnimation="Fade"
                   AllowsTransparency="True"
                   VerticalOffset="5"
                   HorizontalOffset="8">
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        MinWidth="280"
                        Effect="{StaticResource MaterialDesignShadowDepth4}">
                    <StackPanel Margin="0,8,0,8">
                        <!-- 刷新 -->
                        <Button Style="{StaticResource MenuButtonStyle}"
                                Click="RefreshButton_Click"
                                ToolTip="刷新页面 (F5)">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Refresh" 
                                                        Grid.Column="0"
                                                        Width="20" Height="20"
                                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                          Text="刷新页面" 
                                          VerticalAlignment="Center"
                                          Margin="16,0,0,0"
                                          FontSize="14"/>
                            </Grid>
                        </Button>
                        
                        <Separator Background="{DynamicResource MaterialDesignDivider}" Margin="8,8"/>
                        
                        <!-- 不退出进程 -->
                        <Button Style="{StaticResource MenuButtonStyle}"
                                Click="SoftExitButton_Click"
                                ToolTip="仅关闭窗口，CoPaw 服务继续运行">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="LogoutVariant" 
                                                        Grid.Column="0"
                                                        Width="20" Height="20"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                          Text="退出（保持服务）" 
                                          VerticalAlignment="Center"
                                          Margin="16,0,0,0"
                                          FontSize="14"/>
                            </Grid>
                        </Button>
                        
                        <!-- 强制退出 -->
                        <Button Style="{StaticResource MenuButtonStyle}"
                                Click="ForceExitButton_Click"
                                ToolTip="关闭窗口并停止 CoPaw 服务">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="PowerOff" 
                                                        Grid.Column="0"
                                                        Width="20" Height="20"
                                                        Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                          Text="强制退出" 
                                          VerticalAlignment="Center"
                                          Margin="16,0,0,0"
                                          FontSize="14"
                                          Foreground="{DynamicResource SecondaryHueMidBrush}"
                                          FontWeight="SemiBold"/>
                            </Grid>
                        </Button>
                        
                        <Separator Background="{DynamicResource MaterialDesignDivider}" Margin="8,8"/>
                        
                        <!-- 设置 -->
                        <Button Style="{StaticResource MenuButtonStyle}"
                                Click="SettingsButton_Click"
                                ToolTip="自定义主题和外观">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="SettingsOutline" 
                                                        Grid.Column="0"
                                                        Width="20" Height="20"
                                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                          Text="设置" 
                                          VerticalAlignment="Center"
                                          Margin="16,0,0,0"
                                          FontSize="14"/>
                            </Grid>
                        </Button>
                        
                        <Separator Background="{DynamicResource MaterialDesignDivider}" Margin="8,8"/>
                        
                        <!-- 关于 -->
                        <Button Style="{StaticResource MenuButtonStyle}"
                                Click="AboutButton_Click"
                                ToolTip="查看应用信息">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Information" 
                                                        Grid.Column="0"
                                                        Width="20" Height="20"
                                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                          Text="关于" 
                                          VerticalAlignment="Center"
                                          Margin="16,0,0,0"
                                          FontSize="14"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </materialDesign:DialogHost>
</Window>
