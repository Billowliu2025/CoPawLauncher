<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    
    <!-- 应用程序图标 -->
    <ApplicationIcon>app.ico</ApplicationIcon>
    
    <!-- 程序集信息 -->
    <AssemblyName>CoPawLauncher</AssemblyName>
    <RootNamespace>CoPawLauncher</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>Bill</Authors>
    <Company>CoPaw</Company>
    <Product>CoPaw Launcher</Product>
    <Description>CoPaw 快捷启动器 - 快速启动 CoPaw 应用</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MaterialDesignThemes" Version="5.1.0" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2210.55" />
  </ItemGroup>

  <!-- 确保图标文件包含在项目中 -->
  <ItemGroup>
    <Content Include="app.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
