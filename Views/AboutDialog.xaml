<UserControl x:Class="CoPawLauncher.Views.AboutDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="420"
             Width="420"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题和图标 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="RocketLaunch" 
                                    Width="64" Height="64"
                                    Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="CoPaw Launcher" 
                       FontSize="24" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
            <TextBlock x:Name="VersionText"
                       Text="版本 1.0.0" 
                       FontSize="14"
                       Opacity="0.7"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 描述信息 -->
        <Border Grid.Row="1" 
                Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="CoPaw 快捷启动器" 
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="一个基于 WPF (.NET 10) 的 CoPaw 快捷启动应用程序，内嵌 WebView2 浏览器直接访问 CoPaw 聊天界面。"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Opacity="0.8"
                           LineHeight="20"/>
                
                <Separator Margin="0,12,0,12" Background="{DynamicResource MaterialDesignDivider}"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <materialDesign:PackIcon Kind="CodeTags" 
                                            Width="16" Height="16"
                                            Margin="0,0,8,0"
                                            Opacity="0.7"/>
                    <TextBlock Text="技术栈：WPF, .NET 10, WebView2, MaterialDesign"
                               FontSize="12"
                               Opacity="0.7"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <materialDesign:PackIcon Kind="License" 
                                            Width="16" Height="16"
                                            Margin="0,0,8,0"
                                            Opacity="0.7"/>
                    <TextBlock Text="许可证：MIT License"
                               FontSize="12"
                               Opacity="0.7"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <materialDesign:PackIcon Kind="Github" 
                                            Width="16" Height="16"
                                            Margin="0,0,8,0"
                                            Opacity="0.7"/>
                    <TextBlock FontSize="12" Opacity="0.7">
                        <Hyperlink NavigateUri="https://github.com/Billowliu2025/CoPawLauncher"
                                  RequestNavigate="GitHubLink_RequestNavigate">
                            GitHub: Billowliu2025/CoPawLauncher
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 版本更新区域 -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,16">
            <StackPanel>
                <!-- 第一行：状态 + 按钮 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 状态图标 -->
                    <materialDesign:PackIcon x:Name="UpdateIcon"
                                            Kind="Update"
                                            Grid.Column="0"
                                            Width="20" Height="20"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0"/>

                    <!-- 检查中的加载动画 -->
                    <ProgressBar x:Name="UpdateSpinner"
                                 Grid.Column="0"
                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True"
                                 Width="20" Height="20"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"
                                 Visibility="Collapsed"/>

                    <!-- 状态文字 -->
                    <TextBlock x:Name="UpdateStatusText"
                               Grid.Column="1"
                               Text="点击检查是否有新版本"
                               FontSize="13"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>

                    <!-- 检查/下载/安装 按钮 -->
                    <Button x:Name="CheckUpdateButton"
                            Grid.Column="2"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="CheckUpdateButton_Click"
                            Padding="12,4"
                            Height="32"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            VerticalAlignment="Center"
                            Content="检查更新"/>
                </Grid>

                <!-- 下载进度条（默认隐藏） -->
                <Grid x:Name="DownloadProgressPanel" 
                      Visibility="Collapsed"
                      Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ProgressBar x:Name="DownloadProgressBar"
                                 Grid.Row="0"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 Minimum="0" Maximum="100"
                                 Value="0"
                                 Height="6"/>
                    <TextBlock x:Name="DownloadProgressText"
                               Grid.Row="1"
                               Text="准备下载..."
                               FontSize="11"
                               Opacity="0.7"
                               Margin="0,4,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 关闭按钮 -->
        <Button Grid.Row="3"
                Style="{StaticResource MaterialDesignRaisedButton}"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"
                Padding="24,8"
                materialDesign:ButtonAssist.CornerRadius="8"
                Content="关闭"/>
    </Grid>
</UserControl>
